---
/**
 * CTA Section (ContactCTA)
 * ────────────────────────
 * Full-width call-to-action strip used at the bottom of every service page.
 * Drives users toward contacting, calling, or messaging.
 *
 * Props:
 *   title    — heading text
 *   subtitle — supporting sentence
 *   variant  — 'brand' (blue bg) | 'light' (white bg with border) | 'dark'
 *
 * Usage:
 *   <ContactCTA />
 *   <ContactCTA title="Need it fast?" subtitle="Walk in — no appointment needed." />
 *   <ContactCTA variant="light" />
 */
import { siteConfig } from '../../data/siteConfig';

export type CTAVariant = 'brand' | 'light' | 'dark';

interface Props {
  title?: string;
  subtitle?: string;
  variant?: CTAVariant;
  id?: string;
}

const {
  title   = 'Ready to print?',
  subtitle = "Walk in, call us, or drop a message — we'll get your order ready fast.",
  variant = 'brand',
  id,
} = Astro.props;

const wrapperClass = {
  brand: 'bg-gradient-to-br from-brand-700 to-brand-900',
  light: 'bg-white border-y border-gray-200',
  dark:  'bg-gray-900',
}[variant];

const headingClass = {
  brand: 'text-white',
  light: 'text-gray-900',
  dark:  'text-white',
}[variant];

const subtitleClass = {
  brand: 'text-brand-200',
  light: 'text-gray-500',
  dark:  'text-gray-400',
}[variant];
---

<section
  id={id}
  class={`relative overflow-hidden ${wrapperClass}`}
  aria-labelledby="cta-heading"
>
  <!-- Decorative blobs (brand variant only) -->
  {variant === 'brand' && (
    <>
      <div class="absolute -left-20 -top-20 h-64 w-64 rounded-full bg-brand-600/30 blur-3xl" aria-hidden="true" />
      <div class="absolute -bottom-16 -right-16 h-56 w-56 rounded-full bg-brand-500/20 blur-3xl" aria-hidden="true" />
    </>
  )}

  <div class="container-content relative mx-auto px-4 py-14 sm:px-6 sm:py-16 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">

      <!-- Heading -->
      <h2
        id="cta-heading"
        class={`heading-md text-balance ${headingClass}`}
      >
        {title}
      </h2>
      <p class={`mt-3 text-balance text-base leading-relaxed ${subtitleClass}`}>
        {subtitle}
      </p>

      <!-- Action buttons -->
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">

        <!-- Phone call -->
        <a
          href={`tel:${siteConfig.phone.replace(/\s/g, '')}`}
          class:list={[
            'btn btn-lg w-full sm:w-auto',
            variant === 'light' ? 'btn-primary' : 'btn-white',
          ]}
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {siteConfig.phone}
        </a>

        <!-- Contact page -->
        <a
          href="/contact/"
          class:list={[
            'btn btn-lg w-full sm:w-auto',
            variant === 'light' ? 'btn-outline' : 'btn-white-outline',
          ]}
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Contact Us
        </a>

        <!-- Messenger (if configured) -->
        {siteConfig.messengerUrl && (
          <a
            href={siteConfig.messengerUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-lg w-full bg-[#0084FF] text-white hover:bg-[#0078eb] sm:w-auto"
            aria-label="Message us on Messenger (opens in new tab)"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.145 2 11.259c0 2.862 1.332 5.424 3.424 7.17V22l3.168-1.748A10.63 10.63 0 0012 20.517c5.523 0 10-4.144 10-9.258C22 6.145 17.523 2 12 2zm1.008 12.468L10.59 11.9l-4.813 2.567 5.29-5.617 2.418 2.567 4.812-2.567-5.29 5.618z" />
            </svg>
            Message Us
          </a>
        )}
      </div>
    </div>
  </div>
</section>
