---
/**
 * ContactInfo.astro
 * Displays business address, phone, email, hours, and an embedded map.
 * Used on the Contact page.
 */
import { siteConfig } from '../../data/siteConfig';
---

<div class="grid grid-cols-1 gap-10 lg:grid-cols-2">

  <!-- Contact details -->
  <div class="space-y-6">

    <!-- Phone -->
    <div class="flex gap-4">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600" aria-hidden="true">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Phone</p>
        <a
          href={`tel:${siteConfig.phone.replace(/\s/g, '')}`}
          class="text-base font-semibold text-gray-900 hover:text-brand-600"
        >
          {siteConfig.phone}
        </a>
      </div>
    </div>

    <!-- Email -->
    <div class="flex gap-4">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600" aria-hidden="true">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Email</p>
        <a
          href={`mailto:${siteConfig.email}`}
          class="text-base font-semibold text-gray-900 hover:text-brand-600"
        >
          {siteConfig.email}
        </a>
      </div>
    </div>

    <!-- Address -->
    <div class="flex gap-4">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600" aria-hidden="true">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Address</p>
        <a
          href={siteConfig.googleMapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-base font-semibold text-gray-900 hover:text-brand-600"
        >
          {siteConfig.address}
        </a>
      </div>
    </div>

    <!-- Business hours -->
    <div class="rounded-xl border border-gray-200 bg-gray-50 p-5">
      <h3 class="mb-3 font-display text-base font-bold text-gray-900">Business Hours</h3>
      <ul class="space-y-2">
        {siteConfig.businessHours.map((item) => (
          <li class="flex justify-between text-sm">
            <span class="text-gray-500">{item.day}</span>
            <span class:list={['font-medium', item.hours === 'Closed' ? 'text-red-500' : 'text-gray-800']}>
              {item.hours}
            </span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Messaging CTAs -->
    <div class="flex flex-wrap gap-3">
      {siteConfig.messengerUrl && (
        <a
          href={siteConfig.messengerUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700"
        >
          Message on Facebook
        </a>
      )}
      {siteConfig.whatsappUrl && (
        <a
          href={siteConfig.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md bg-green-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-green-700"
        >
          Chat on WhatsApp
        </a>
      )}
    </div>
  </div>

  <!-- Embedded map -->
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-gray-100">
    <iframe
      src={siteConfig.googleMapsEmbedUrl}
      width="100%"
      height="400"
      style="border:0;"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="LK Print location on Google Maps"
      class="w-full"
    ></iframe>
  </div>

</div>
