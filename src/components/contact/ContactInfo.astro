---
import { siteConfig } from '../../data/siteConfig';
---

<div class="space-y-6">

  <!-- Phone -->
  <div class="flex gap-4">
    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600" aria-hidden="true">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
    </div>
    <div>
      <p class="text-sm font-medium text-gray-500">Phone</p>
      <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="text-base font-semibold text-gray-900 hover:text-brand-600">
        {siteConfig.phone}
      </a>
    </div>
  </div>

  <!-- Email -->
  <div class="flex gap-4">
    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600" aria-hidden="true">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    </div>
    <div>
      <p class="text-sm font-medium text-gray-500">Email</p>
      <a href={`mailto:${siteConfig.email}`} class="text-base font-semibold text-gray-900 hover:text-brand-600">
        {siteConfig.email}
      </a>
    </div>
  </div>

  <!-- Address -->
  <div class="flex gap-4">
    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600" aria-hidden="true">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
    </div>
    <div>
      <p class="text-sm font-medium text-gray-500">Address</p>
      <a href={siteConfig.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="text-base font-semibold text-gray-900 hover:text-brand-600">
        {siteConfig.address}
      </a>
    </div>
  </div>

  <!-- Business Hours -->
  <div class="flex gap-4">
    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600" aria-hidden="true">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    <div>
      <p class="text-sm font-medium text-gray-500">Business Hours</p>
      <ul class="mt-1 space-y-1">
        {siteConfig.businessHours.map((item) => (
          <li class="flex gap-2 text-sm">
            <span class="text-gray-500">{item.day}</span>
            <span class:list={['font-medium', item.hours === 'Closed' ? 'text-red-500' : 'text-gray-800']}>
              {item.hours}
            </span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Social -->
  <div class="flex gap-4">
    <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600" aria-hidden="true">
      <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
      </svg>
    </div>
    <div class="flex flex-col gap-2">
      <p class="text-sm font-medium text-gray-500">Social</p>
      {siteConfig.facebookUrl && (
        <a href={siteConfig.facebookUrl} target="_blank" rel="noopener noreferrer" class="text-base font-semibold text-gray-900 hover:text-brand-600">
          Facebook Page
        </a>
      )}
      {siteConfig.messengerUrl && (
        <a href={siteConfig.messengerUrl} target="_blank" rel="noopener noreferrer" class="text-base font-semibold text-gray-900 hover:text-brand-600">
          Message on Messenger
        </a>
      )}
    </div>
  </div>

</div>
