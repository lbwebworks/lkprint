---
/**
 * Footer
 * ──────
 * Site-wide footer — 4-column grid on desktop, stacked on mobile.
 *
 * Columns:
 *   1. Brand + tagline + social icons
 *   2. Services quick-links
 *   3. Business hours
 *   4. Contact details
 */
import { siteConfig } from '../../data/siteConfig';

const year = new Date().getFullYear();

const serviceLinks = siteConfig.navLinks.filter(l => l.href !== '/');
---

<footer class="bg-brand-900 text-gray-400" role="contentinfo">

  <!-- ── Main grid ─────────────────────────────────────────────────────── -->
  <div class="container-content mx-auto px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand column ─────────────────────────────────────────────────── -->
      <div class="sm:col-span-2 lg:col-span-1">

        <!-- Logo -->
        <a
          href="/"
          class="group mb-4 inline-flex items-center gap-2.5 font-display text-xl font-extrabold text-white"
          aria-label="Go to homepage"
        >
          <span
            class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand-600 text-sm font-extrabold text-white transition-transform duration-150 group-hover:scale-105"
            aria-hidden="true"
          >
            LK
          </span>
          {siteConfig.businessName}
        </a>

        <p class="mb-5 max-w-xs text-sm leading-relaxed text-gray-400">
          {siteConfig.tagline}. Quality printing services for students, professionals, and businesses.
        </p>

        <!-- Social icons -->
        <div class="flex gap-2" role="list" aria-label="Social media links">
          {siteConfig.facebookUrl && (
            <a
              href={siteConfig.facebookUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-gray-400 transition-colors hover:bg-brand-600 hover:text-white"
              aria-label="Follow us on Facebook"
              role="listitem"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
              </svg>
            </a>
          )}
          {siteConfig.messengerUrl && (
            <a
              href={siteConfig.messengerUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-gray-400 transition-colors hover:bg-blue-500 hover:text-white"
              aria-label="Message us on Messenger"
              role="listitem"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.145 2 11.259c0 2.862 1.332 5.424 3.424 7.17V22l3.168-1.748A10.63 10.63 0 0012 20.517c5.523 0 10-4.144 10-9.258C22 6.145 17.523 2 12 2zm1.008 12.468L10.59 11.9l-4.813 2.567 5.29-5.617 2.418 2.567 4.812-2.567-5.29 5.618z" />
              </svg>
            </a>
          )}
          {siteConfig.whatsappUrl && (
            <a
              href={siteConfig.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-gray-400 transition-colors hover:bg-green-500 hover:text-white"
              aria-label="Chat with us on WhatsApp"
              role="listitem"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.136.561 4.14 1.535 5.874L.057 23.43l5.7-1.496A11.949 11.949 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.808 9.808 0 01-5.031-1.385l-.36-.214-3.733.979.999-3.645-.235-.374A9.818 9.818 0 012.182 12C2.182 6.565 6.565 2.182 12 2.182S21.818 6.565 21.818 12 17.435 21.818 12 21.818z" />
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- Services links ───────────────────────────────────────────────── -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-gray-500">
          Our Services
        </h3>
        <ul class="space-y-2.5 text-sm" role="list">
          {serviceLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="flex items-center gap-2 text-gray-400 transition-colors hover:text-white"
              >
                <svg class="h-3 w-3 text-brand-500 shrink-0" fill="currentColor" viewBox="0 0 6 6" aria-hidden="true">
                  <circle cx="3" cy="3" r="3" />
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Business hours ───────────────────────────────────────────────── -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-gray-500">
          Store Hours
        </h3>
        <ul class="space-y-2 text-sm" role="list">
          {siteConfig.businessHours.map((item) => (
            <li class="flex items-center justify-between gap-4">
              <span class="text-gray-400">{item.day}</span>
              <span class:list={[
                'font-medium tabular-nums',
                item.hours === 'Closed' ? 'text-red-400' : 'text-gray-200',
              ]}>
                {item.hours}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact info ─────────────────────────────────────────────────── -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-gray-500">
          Contact
        </h3>
        <ul class="space-y-3.5 text-sm" role="list">
          <li>
            <a
              href={`tel:${siteConfig.phone.replace(/\s/g, '')}`}
              class="flex items-start gap-2.5 text-gray-400 transition-colors hover:text-white"
            >
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {siteConfig.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${siteConfig.email}`}
              class="flex items-start gap-2.5 text-gray-400 transition-colors hover:text-white"
            >
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {siteConfig.email}
            </a>
          </li>
          <li>
            <a
              href={siteConfig.googleMapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-start gap-2.5 text-gray-400 transition-colors hover:text-white"
            >
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="leading-snug">{siteConfig.address}</span>
            </a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- ── Bottom bar ────────────────────────────────────────────────────── -->
  <div class="border-t border-white/5">
    <div class="container-content mx-auto flex flex-col items-center justify-between gap-2 px-4 py-5 text-xs text-gray-600 sm:flex-row sm:px-6 lg:px-8">
      <span>© {year} {siteConfig.businessName}. All rights reserved.</span>
      <span class="hidden sm:block">Quality prints, fast service.</span>
    </div>
  </div>

</footer>
