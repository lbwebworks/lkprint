---
/**
 * PackageCard
 * ───────────
 * Photo package card with preview image, print sizes, price, and order CTA.
 *
 * Props:
 *   package  — PhotoPackage from data/photoPackages.ts
 *   priority — if true, renders image as eager (use for above-the-fold cards)
 *
 * Usage:
 *   <PackageCard package={pkg} />
 *   <PackageCard package={pkg} priority />
 */
import type { PhotoPackage } from '../../types';

const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');

interface Props {
  package: PhotoPackage;
  priority?: boolean;
}

const { package: pkg, priority = false } = Astro.props;

const badgeVariantClass =
  pkg.badge === 'Best Value'
    ? 'badge-accent'
    : pkg.badge === 'Popular'
    ? 'badge-brand'
    : 'badge-gray';
---

<article
  class="group flex flex-col overflow-hidden rounded-xl border border-gray-200 bg-white transition-all duration-200 hover:-translate-y-0.5 cursor-pointer"
  style="box-shadow: var(--shadow-card);"
  data-package-id={pkg.id}
  data-package-name={pkg.name}
  data-package-image={`${base}${pkg.imagePreview.startsWith('/') ? pkg.imagePreview : '/' + pkg.imagePreview}`}
  data-package-alt={pkg.imageAlt}
  onmouseenter="this.style.boxShadow='var(--shadow-card-hover)'"
  onmouseleave="this.style.boxShadow='var(--shadow-card)'"
>
  <!-- ── Preview image ─────────────────────────────────────────────── -->
  <div class="relative aspect-[4/3] overflow-hidden bg-surface-100">
    <img
      src={`${base}${pkg.imagePreview.startsWith('/') ? pkg.imagePreview : '/' + pkg.imagePreview}`}
      alt={pkg.imageAlt}
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      width="400"
      height="300"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
    />

    <!-- Gradient overlay for readability -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" aria-hidden="true" />

    <!-- Badge -->
    {pkg.badge && (
      <div class="absolute left-3 top-3">
        <span class={`badge ${badgeVariantClass}`}>
          {pkg.badge === 'Popular' && (
            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          )}
          {pkg.badge}
        </span>
      </div>
    )}

    <!-- Featured ribbon -->
    {pkg.featured && !pkg.badge && (
      <div class="absolute right-0 top-0 overflow-hidden" aria-hidden="true">
        <div class="flex h-14 w-14 items-start justify-end bg-brand-600">
          <svg class="m-1.5 h-4 w-4 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        </div>
        <div class="h-0 w-0 border-l-[3.5rem] border-t-[3.5rem] border-l-transparent border-t-brand-600 -mt-14" />
      </div>
    )}
  </div>

  <!-- ── Card body ─────────────────────────────────────────────────── -->
  <div class="flex flex-1 flex-col p-4">

    <!-- Name -->
    <div>
      <h3 class="font-display text-base font-bold text-gray-900">{pkg.name}</h3>
    </div>

    <!-- Description -->
    <p class="body-sm mt-2.5 flex-1 line-clamp-2">{pkg.description}</p>

    <!-- Price info -->
    <div class="mt-4 border-t border-gray-100 pt-4">
      {pkg.priceFrom ? (
        <p class="font-display text-xl font-extrabold text-brand-700 leading-none">
          ₱{pkg.priceFrom.toFixed(2)}
        </p>
      ) : (
        <p class="label-xs text-gray-500">Price on request</p>
      )}
    </div>
  </div>
</article>
