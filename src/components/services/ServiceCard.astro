---
/**
 * ServiceCard
 * ───────────
 * Displays a single service with icon, title, description, optional price note,
 * and a learn-more link.
 *
 * Props:
 *   service  — ServiceItem from data/services.ts
 *   variant  — 'default' card layout | 'compact' horizontal layout | 'featured' larger card
 *
 * Usage:
 *   <ServiceCard service={item} />
 *   <ServiceCard service={item} variant="compact" />
 *   <ServiceCard service={item} variant="featured" />
 */
import type { ServiceItem } from '../../types';

export type ServiceCardVariant = 'default' | 'compact' | 'featured';

interface Props {
  service: ServiceItem;
  variant?: ServiceCardVariant;
}

const { service, variant = 'default' } = Astro.props;

// Map icon names to SVG paths
const iconPaths: Record<string, string> = {
  printer:         'M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6z',
  'color-swatch':  'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
  copy:            'M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2',
  scan:            'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18',
  edit:            'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
  photograph:      'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z',
  identification:  'M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2',
  'shield-check':  'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  'book-open':     'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
};

const defaultPath = 'M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z';
const svgPath = iconPaths[service.icon] ?? defaultPath;
---

{variant === 'compact' ? (
  <!-- Compact: horizontal layout ─────────────────────────────────────── -->
  <article class="card card-hover flex items-start gap-4 p-4">
    <div class="icon-box icon-box-sm shrink-0" aria-hidden="true">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d={svgPath} />
      </svg>
    </div>
    <div class="min-w-0 flex-1">
      <h3 class="heading-sm text-base leading-snug">{service.title}</h3>
      <p class="body-sm mt-1 line-clamp-2">{service.description}</p>
    </div>
  </article>

) : variant === 'featured' ? (
  <!-- Featured: larger card with accent top border ────────────────────── -->
  <article class="card card-hover flex flex-col gap-5 p-6 border-t-4 border-t-brand-600">
    <div class="icon-box icon-box-lg" aria-hidden="true">
      <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d={svgPath} />
      </svg>
    </div>
    <div class="flex flex-1 flex-col gap-2">
      <h3 class="heading-sm text-lg">{service.title}</h3>
      <p class="body-base flex-1 text-sm">{service.description}</p>
    </div>
  </article>

) : (
  <!-- Default card ────────────────────────────────────────────────────── -->
  <article class="card card-hover flex flex-col gap-4 p-6">
    <!-- Icon -->
    <div class="icon-box icon-box-md" aria-hidden="true">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d={svgPath} />
      </svg>
    </div>

    <!-- Content -->
    <div class="flex flex-1 flex-col gap-2">
      <h3 class="heading-sm">{service.title}</h3>
      <p class="body-sm flex-1">{service.description}</p>
    </div>

    <!-- Link -->
  </article>
)}
