---
/**
 * SectionHeading.astro
 * Consistent h2 + optional subtitle for every page section.
 *
 * Usage:
 *   <SectionHeading
 *     title="Our Services"
 *     subtitle="Everything you need for your printing needs."
 *     centered
 *   />
 */
interface Props {
  title: string;
  subtitle?: string;
  /** Center-align the text (default: left) */
  centered?: boolean;
  /** Render as a different heading level (default: h2) */
  level?: 2 | 3;
  class?: string;
}

const {
  title,
  subtitle,
  centered = false,
  level    = 2,
  class: extraClass = '',
} = Astro.props;

const wrapperClass = [
  'mb-10',
  centered ? 'text-center' : '',
  extraClass,
].join(' ');

const Tag = `h${level}` as 'h2' | 'h3';
---

<div class={wrapperClass}>
  <Tag class="font-display text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
    {title}
  </Tag>
  {subtitle && (
    <p class="mt-3 max-w-2xl text-base text-gray-500 sm:text-lg" class:list={[centered && 'mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
