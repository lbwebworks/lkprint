---
/**
 * Contact page — /contact/
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ContactInfo from '../components/contact/ContactInfo.astro';
import ContactCTA from '../components/contact/ContactCTA.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with LK Print. Visit us in store, call us, or send a message on Facebook or WhatsApp."
>
  <section class="section-padding bg-surface-50">
    <div class="container-content mx-auto">
      <div class="mx-auto max-w-3xl text-center">
        <SectionHeading
          title="Get in touch"
          subtitle="We’re here to help with printing, photo packages, lamination, and rush orders."
          centered
        />
        <p class="text-base text-gray-600">
          Reach out by phone, email, or quick chat. Visit our store for in-person service or send us a message and we’ll respond right away.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-content mx-auto grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start lg:gap-14">
      <div>
        <ContactInfo />
      </div>

      <div class="space-y-6 rounded-[2rem] border border-gray-200 bg-white p-8 shadow-lg">
        <div class="rounded-3xl bg-brand-50 p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-700">Need help now?</p>
          <h2 class="mt-4 text-3xl font-bold text-gray-900">Message us directly on Facebook Messenger</h2>
          <p class="mt-4 text-gray-600">
            Send a quick message and our team will help you choose the right print options, confirm pricing, or reserve a rush order.
          </p>
          <div class="mt-6">
            <a
              href={siteConfig.messengerUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-blue-700 sm:w-auto"
            >
              Message us on Messenger
            </a>
          </div>
        </div>

        <div class="rounded-3xl border border-gray-200 bg-surface-50 p-6">
          <h3 class="text-lg font-semibold text-gray-900">Location</h3>
          <p class="mt-2 text-gray-600">{siteConfig.address}</p>
          <a
            href={siteConfig.googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-brand-700 hover:text-brand-900"
          >
            View on Google Maps
          </a>
        </div>

        <div class="rounded-3xl border border-gray-200 bg-surface-50 p-6">
          <h3 class="text-lg font-semibold text-gray-900">Social</h3>
          <div class="mt-4 space-y-3">
            {siteConfig.facebookUrl && (
              <a
                href={siteConfig.facebookUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm font-medium text-gray-700 hover:border-brand-300 hover:text-brand-700"
              >
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-blue-50 text-blue-700">F</span>
                Visit our Facebook page
              </a>
            )}
            {siteConfig.messengerUrl && (
              <a
                href={siteConfig.messengerUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm font-medium text-gray-700 hover:border-brand-300 hover:text-brand-700"
              >
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-blue-50 text-blue-700">M</span>
                Message us on Messenger
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA
    title="Ready to start your order?"
    subtitle="Message us now and we’ll help you prepare the best print or photo package for your needs."
  />
</BaseLayout>
