---
/**
 * Home page — /
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import PackageGrid from '../components/photo/PackageGrid.astro';
import ContactCTA from '../components/contact/ContactCTA.astro';
import { featuredPackages } from '../data/photoPackages';
---

<BaseLayout
  title="Quality printing, fast service"
  description="Discover LK Print’s document printing, photo printing, lamination, and fast contact options for local customers."
>
  <Hero
    headline="Fast, affordable printing
for every need"
    subheadline="From school requirements to business documents and photo keepsakes — LK Print makes every order easy, affordable, and ready when you need it."
  />

  <section class="section-padding bg-surface-50">
    <div class="container-content mx-auto">
      <SectionHeading
        title="Our Services"
        subtitle="Top printing solutions for students, businesses, and everyday needs."
        centered
      />

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/lkprint/document/" class="card card-hover flex flex-col gap-4 p-6">
          <div class="icon-box icon-box-md" aria-hidden="true">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
          </div>
          <div>
            <h3 class="heading-sm">Document Printing</h3>
            <p class="body-sm mt-1">Black & white and colored document printing in A4, short, and legal sizes.</p>
          </div>
        </a>
        <a href="/lkprint/photo/" class="card card-hover flex flex-col gap-4 p-6">
          <div class="icon-box icon-box-md" aria-hidden="true">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </div>
          <div>
            <h3 class="heading-sm">Photo Printing</h3>
            <p class="body-sm mt-1">Print your memories in glossy finishes across wallet sizes, R-series, and large formats.</p>
          </div>
        </a>
        <a href="/lkprint/lamination/" class="card card-hover flex flex-col gap-4 p-6">
          <div class="icon-box icon-box-md" aria-hidden="true">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <div>
            <h3 class="heading-sm">Lamination</h3>
            <p class="body-sm mt-1">Protect your documents and photos with glossy or matte lamination in all common sizes.</p>
          </div>
        </a>
        <a href="/lkprint/others/" class="card card-hover flex flex-col gap-4 p-6">
          <div class="icon-box icon-box-md" aria-hidden="true">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
          </div>
          <div>
            <h3 class="heading-sm">Other Services</h3>
            <p class="body-sm mt-1">Scanning, editing, rush orders, background removal, and photo enhancements.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section-padding bg-surface-50">
    <div class="container-content mx-auto">
      <SectionHeading
        title="Featured Photo Packages"
        subtitle="Popular photo print packages ready for quick pickup or delivery."
        centered
      />

      <PackageGrid packages={featuredPackages} columns={3} eagerCount={3} />

      <div class="mt-10 text-center">
        <a href="/lkprint/photo/" class="btn btn-outline btn-lg">
          Browse photo printing
        </a>
      </div>
    </div>
  </section>

  <!-- Package Modal -->
  <div id="package-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/50 p-4 backdrop-blur-sm">
    <div class="relative max-h-[90vh] max-w-2xl w-full bg-white rounded-2xl overflow-hidden shadow-2xl flex flex-col">
      <button
        id="modal-close"
        type="button"
        class="absolute top-4 right-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/80 text-gray-600 transition hover:bg-white hover:text-gray-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500"
        aria-label="Close modal"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <div class="flex-1 overflow-auto bg-surface-100 flex items-center justify-center min-h-0">
        <img id="modal-image" src="" alt="" class="max-w-full max-h-[60vh] object-contain" />
      </div>
      <div class="border-t border-gray-200 bg-white p-6">
        <h3 id="modal-title" class="font-display text-xl font-bold text-gray-900"></h3>
        <p id="modal-description" class="mt-2 text-gray-600"></p>
      </div>
    </div>
  </div>

  <script type="module">
    const packageCards = document.querySelectorAll('[data-package-id]');
    const modal = document.getElementById('package-modal');
    const modalClose = document.getElementById('modal-close');
    const modalImage = document.getElementById('modal-image');
    const modalTitle = document.getElementById('modal-title');
    const modalDescription = document.getElementById('modal-description');

    const openModal = (card) => {
      modalImage.src = card.dataset.packageImage;
      modalImage.alt = card.dataset.packageAlt;
      modalTitle.textContent = card.dataset.packageName;
      modalDescription.textContent = card.querySelector('.body-sm')?.textContent || '';
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
      modal.classList.add('hidden');
      document.body.style.overflow = 'auto';
    };

    packageCards.forEach((card) => {
      card.addEventListener('click', (e) => { if (e.button === 0) openModal(card); });
    });

    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
    });
  </script>

  <ContactCTA
    title="Ready to print with LK Print?"
    subtitle="Call, message, or visit us today and we’ll help you finish your order quickly."
  />
</BaseLayout>
