---
/**
 * Lamination & Finishing page — /lamination-finishing/
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ServiceCard from '../components/services/ServiceCard.astro';
import PricingTable from '../components/ui/PricingTable.astro';
import ContactCTA from '../components/contact/ContactCTA.astro';
import Card from '../components/ui/Card.astro';
import { finishingServices } from '../data/services';

const laminationPricing = [
  { option: '65×95 mm', price: '₱10', details: 'Compact lamination for IDs, cards, and small photos' },
  { option: '75×105 mm', price: '₱15', details: 'Small-size lamination for tags and small printed items' },
  { option: '85×115 mm', price: '₱20', details: 'Photo-size lamination for keepsakes and passes' },
  { option: '100×135 mm', price: '₱25', details: 'Large-format lamination for certificates and small posters' },
  { option: 'Short', price: '₱35', details: 'Short-size document or photo lamination' },
  { option: 'A4', price: '₱40', details: 'Standard A4 lamination for documents and certificates' },
  { option: 'Long', price: '₱50', details: 'Long-size lamination for banners and elongated prints' },
];

const rushPricing = [
  { option: 'Priority rush fee', price: '₱10–₱30', details: 'Additional charge for urgent finishing orders' },
  { option: 'Same-day rush', price: '₱50.00', details: 'Priority handling for orders completed before closing' },
  { option: 'Within 2 hours', price: '₱100.00', details: 'Fastest processing for urgent lamination orders' },
];

const notes = [
  'Heavy ink coverage should be charged as Full-Page Colored Image.',
  'Dark background prints may incur additional charges.',
  'Premium quality printing may have additional fees.',
  'Reprints caused by customer file errors are chargeable.',
  'Rush orders may incur priority fees.',
  'Waterproof stickers cost more due to material costs.',
];
---

<BaseLayout
  title="Lamination"
  description="Protect your documents with glossy or matte lamination and fast finishing service."
>
  <section class="section-padding bg-surface-50">
    <div class="container-content mx-auto lg:grid lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-14">
      <div>
        <SectionHeading
          title="Lamination"
          subtitle="Protect papers, presentations, and keepsakes with premium lamination and rush finishing."
        />
        <p class="text-gray-600">
          Keep your documents crisp, durable, and presentation-ready. Our finishing services are designed for student projects, business materials, and personal keepsakes.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <Card hover padding="lg" class="border-brand-100 bg-white">
            <h3 class="text-lg font-semibold text-gray-900">Glossy & matte options</h3>
            <p class="mt-2 text-sm text-gray-600">Choose glossy for vibrant color or matte for a glare-free professional look.</p>
          </Card>
          <Card hover padding="lg" class="border-brand-100 bg-white">
            <h3 class="text-lg font-semibold text-gray-900">Fast turnaround</h3>
            <p class="mt-2 text-sm text-gray-600">Need it today? Ask about rush service and same-day finishing on selected orders.</p>
          </Card>
        </div>
      </div>

      <div class="mt-10 lg:mt-0">
        <div class="rounded-[2rem] border border-gray-200 bg-white p-8 shadow-lg">
          <h3 class="text-xl font-semibold text-gray-900">Our lamination service</h3>
          <p class="mt-3 text-gray-600">
            We help turn your documents and photos into polished, ready-to-use prints with premium lamination.
          </p>
          <div class="mt-6 space-y-4">
            {finishingServices.map((service) => (
              <ServiceCard key={service.id} service={service} variant="compact" />
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-content mx-auto">
      <SectionHeading
        title="Lamination Pricing"
        subtitle="Transparent pricing for document and photo lamination in all common sizes."
      />

      <PricingTable rows={laminationPricing} />
    </div>
  </section>

  <section class="section-padding">
    <div class="container-content mx-auto">
      <SectionHeading
        title="Rush Service"
        subtitle="Need your order today? Add a rush fee for priority finishing and early pickup."
      />

      <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start lg:gap-14">
        <div>
          <p class="text-gray-600">
            Our rush service is ideal when you need lamination quickly. Availability depends on order volume, so call ahead to secure a fast turnaround.
          </p>
          <PricingTable rows={rushPricing} />
        </div>
        <div class="rounded-[2rem] border border-brand-100 bg-brand-50 p-7">
          <h3 class="text-lg font-semibold text-brand-900">Rush service perks</h3>
          <ul class="mt-4 space-y-3 text-brand-700">
            <li>Priority order handling</li>
            <li>Shorter wait time in-store</li>
            <li>Flexible after-hours support</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-surface-50">
    <div class="container-content mx-auto">
      <SectionHeading
        title="Additional Notes"
        subtitle="Helpful details to ensure your finishing order goes smoothly."
      />

      <div class="grid gap-6 sm:grid-cols-2">
        {notes.map((note) => (
          <Card hover padding="lg" class="bg-white">
            <p class="text-gray-700">{note}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <ContactCTA
    title="Ready to finish your documents?"
    subtitle="Contact us today to arrange lamination or rush service for your next order."
  />
</BaseLayout>
