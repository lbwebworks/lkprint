---
/**
 * Lamination & Finishing page — /lamination-finishing/
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import PricingTable from '../components/ui/PricingTable.astro';
import Card from '../components/ui/Card.astro';

const laminationPricing = [
  { option: '65×95 mm', price: '₱10', details: 'Compact lamination for IDs, cards, and small photos' },
  { option: '75×105 mm', price: '₱15', details: 'Small-size lamination for tags and small printed items' },
  { option: '85×115 mm', price: '₱20', details: 'Photo-size lamination for keepsakes and passes' },
  { option: '100×135 mm', price: '₱25', details: 'Large-format lamination for certificates and small posters' },
  { option: 'A4', price: '₱40', details: 'Standard A4 lamination for documents and certificates' },
];

const notes = [
  'Heavy ink coverage should be charged as Full-Page Colored Image.',
  'Dark background prints may incur additional charges.',
  'Premium quality printing may have additional fees.',
  'Reprints caused by customer file errors are chargeable.',
  'Rush orders may incur priority fees.',
  'Waterproof stickers cost more due to material costs.',
];
---

<BaseLayout
  title="Lamination Service"
  description="Protect your documents with glossy or matte lamination and fast finishing service."
>
  <section class="section-padding bg-surface-50">
    <div class="container-content mx-auto lg:grid lg:items-center lg:gap-14">
      <div>
        <SectionHeading
          title="Lamination Service"
          subtitle="Protect papers, presentations, and keepsakes with premium lamination and rush finishing."
        />
        <p class="text-gray-600">
          Keep your documents crisp, durable, and presentation-ready. Our finishing services are designed for student projects, business materials, and personal keepsakes.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-content mx-auto">
      <SectionHeading
        title="Lamination Pricing"
        subtitle="Transparent pricing for document and photo lamination in all common sizes."
      />

      <PricingTable rows={laminationPricing} />
    </div>
  </section>

  <section class="section-padding bg-surface-50">
    <div class="container-content mx-auto">
      <SectionHeading
        title="Additional Notes"
        subtitle="Helpful details to ensure your finishing order goes smoothly."
      />

      <div class="grid gap-6 sm:grid-cols-2">
        {notes.map((note) => (
          <Card hover padding="lg" class="bg-white">
            <p class="text-gray-700">{note}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
