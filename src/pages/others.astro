---
/**
 * Other Services page — /others/
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import PricingTable from '../components/ui/PricingTable.astro';

const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');

const othersPricing = [
  { option: 'Scanning',                  price: '₱5',  details: 'High-resolution scanning to PDF or image files' },
  { option: 'Document Editing / Layout', price: '₱20', details: 'Document layout, formatting, and print-ready adjustments' },
  { option: 'Rush Fee',                  price: '₱30', details: 'Priority handling for urgent orders' },
  { option: 'ID Background Removal',     price: '₱25', details: 'Clean background removal for ID photos' },
  { option: 'Basic Background Removal',  price: '₱50', details: 'Background removal for general photos' },
  { option: 'Simple Photo Enhancement',  price: '₱10', details: 'Basic brightness, contrast, and color adjustments' },
];
---

<BaseLayout
  title="Other Services"
  description="Scanning, document editing, rush fees, background removal, and photo enhancement services at LK Print."
>
  <section class="section-padding bg-surface-50">
    <div class="container-content mx-auto">
      <div class="mx-auto max-w-3xl text-center">
        <SectionHeading
          title="Other Services"
          subtitle="Additional services to help you get the most out of your printing experience."
          centered
        />
        <p class="text-base text-gray-600">
          From scanning and editing to rush orders and photo enhancements — we've got you covered.
        </p>
        <div class="mt-8">
          <a href={`${base}/tarpaulin/`} class="btn btn-primary btn-lg">
            View Tarpaulin
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-content mx-auto">
      <PricingTable rows={othersPricing} />
    </div>
  </section>
</BaseLayout>
