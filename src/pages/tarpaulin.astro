---
/**
 * Tarpaulin page — /tarpaulin/
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { siteConfig } from '../data/siteConfig';
import { photoPackages } from '../data/photoPackages';

const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');

const services = [
  { label: 'Photo Printing', icon: 'camera' },
  { label: 'Document Printing', icon: 'printer' },
  { label: 'ID Pictures', icon: 'id' },
  { label: 'Photocopy', icon: 'copy' },
  { label: 'Photo Enhancement', icon: 'spark' },
  { label: 'Scanning', icon: 'scan' },
  { label: 'Background Removal', icon: 'cut' },
  { label: 'Lamination', icon: 'shield' },
];

const packageSelections = [
  { category: 'Basic ID Packages', id: 'id-package-10' },
  { category: 'Mixed ID Packages', id: 'id-package-05' },
  { category: 'Single Prints', id: 'solo-4r' },
  { category: 'Mini Photo Bundles', id: 'a6-combo-2' },
  { category: 'Standard Photo Bundles', id: 'combo-01' },
  { category: 'Creative Bundles', id: 'crazy-combo-2' },
];

const packageHighlights = packageSelections
  .map((selection) => {
    const match = photoPackages.find((pkg) => pkg.id === selection.id);

    if (!match) return undefined;

    return {
      category: selection.category,
      name: match.name,
      description: match.description,
      price: match.price ? `PHP ${match.price.toFixed(2)}` : 'Price on request',
      imageUrl: `${base}${match.imagePreview.startsWith('/') ? match.imagePreview : `/${match.imagePreview}`}`,
    };
  })
  .filter((item): item is {
    category: string;
    name: string;
    description: string;
    price: string;
    imageUrl: string;
  } => Boolean(item));

const samplePrints = packageHighlights.slice(0, 5);

const assetPlaceholders = [
  'Facebook Page QR code',
  'Messenger QR code',
  'Website QR code',
  'Transparent business logo file',
];

const designData = {
  businessName: siteConfig.businessName,
  title: siteConfig.tagline,
  phrase: siteConfig.primaryMarketingMessage,
  welcomePhrase: siteConfig.welcomePhrase,
  serviceArea: siteConfig.serviceArea,
  services,
  packages: packageHighlights,
  samplePrints,
  phone: siteConfig.phone,
  email: siteConfig.email,
  address: siteConfig.address,
  facebookUrl: siteConfig.facebookUrl,
  messengerUrl: siteConfig.messengerUrl,
  websiteUrl: siteConfig.websiteUrl,
};
---

<BaseLayout
  title="Tarpaulin Design Preview"
  description="Preview a sample tarpaulin layout for LK Print with services, package highlights, and contact callouts."
>
  <section class="section-padding bg-surface-50">
    <div class="container-content mx-auto">
      <div class="mx-auto max-w-4xl text-center">
        <SectionHeading
          title="Tarpaulin Design Preview"
          subtitle="A first-pass canvas mockup for a storefront tarpaulin. The QR areas are placeholders for the assets you can provide later."
          centered
        />
        <p class="text-base text-gray-600">
          The layout uses three main rows: a branded top banner, a services and packages middle band, and a contact-focused footer with QR placeholders.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-content mx-auto">
      <div class="card overflow-hidden border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <div class="mb-6 rounded-[1.5rem] border border-surface-200 bg-surface-50 p-4 sm:p-5">
          <div class="grid gap-4 lg:grid-cols-[1.2fr_1.2fr_1fr_auto] lg:items-end">
            <label class="block">
              <span class="mb-2 block text-sm font-semibold text-gray-900">Tarpaulin width</span>
              <input
                id="tarpaulin-width"
                type="number"
                min="1"
                step="0.1"
                value="6"
                class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-base text-gray-900 shadow-sm focus:border-brand-400 focus:outline-none"
              />
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-semibold text-gray-900">Tarpaulin height</span>
              <input
                id="tarpaulin-height"
                type="number"
                min="1"
                step="0.1"
                value="4"
                class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-base text-gray-900 shadow-sm focus:border-brand-400 focus:outline-none"
              />
            </label>

            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
              <label class="block">
                <span class="mb-2 block text-sm font-semibold text-gray-900">Measurement unit</span>
                <select
                  id="tarpaulin-unit"
                  class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-base text-gray-900 shadow-sm focus:border-brand-400 focus:outline-none"
                >
                  <option value="ft" selected>Feet</option>
                  <option value="in">Inches</option>
                  <option value="cm">Centimeters</option>
                  <option value="m">Meters</option>
                </select>
              </label>

              <label class="block">
                <span class="mb-2 block text-sm font-semibold text-gray-900">Export quality</span>
                <select
                  id="tarpaulin-ppi"
                  class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-base text-gray-900 shadow-sm focus:border-brand-400 focus:outline-none"
                >
                  <option value="72">72 PPI</option>
                  <option value="100" selected>100 PPI</option>
                  <option value="150">150 PPI</option>
                </select>
              </label>
            </div>

            <div class="flex flex-col gap-3">
              <button id="tarpaulin-export" type="button" class="btn btn-primary btn-lg w-full">
                Export PNG
              </button>
              <p class="text-xs text-gray-500">
                Preview auto-fits the chosen aspect ratio. Export uses the selected print resolution.
              </p>
            </div>
          </div>

          <div class="mt-4 grid gap-3 rounded-2xl bg-white p-4 shadow-sm sm:grid-cols-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Current size</p>
              <p id="tarpaulin-size-summary" class="mt-1 text-sm font-semibold text-gray-900">6 ft × 4 ft</p>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Aspect ratio</p>
              <p id="tarpaulin-ratio-summary" class="mt-1 text-sm font-semibold text-gray-900">3:2 landscape</p>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Export pixels</p>
              <p id="tarpaulin-pixel-summary" class="mt-1 text-sm font-semibold text-gray-900">7200 × 4800 px at 100 PPI</p>
            </div>
          </div>
        </div>

        <div class="rounded-[1.75rem] bg-gradient-to-br from-brand-950 via-brand-900 to-brand-800 p-3 sm:p-4">
          <canvas
            id="tarpaulin-canvas"
            width="1600"
            height="1000"
            class="block w-full rounded-[1.25rem] bg-white h-auto"
            aria-label="Canvas preview of the LK Print tarpaulin design"
          ></canvas>
        </div>
        <p class="mt-4 text-sm text-gray-500">
          Package images are pulled from the existing photo package assets. QR codes and any custom logo file are intentionally shown as gray placeholders for now.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-surface-50">
    <div class="container-content mx-auto">
      <SectionHeading
        title="Assets Still Needed"
        subtitle="These can replace the gray placeholders in the bottom row and top accent areas once you provide them."
      />

      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
        {assetPlaceholders.map((item) => (
          <div class="card flex min-h-44 flex-col justify-between border-gray-200 bg-white p-5">
            <div class="rounded-2xl bg-gray-200/80 min-h-24 w-full border border-dashed border-gray-300"></div>
            <div class="mt-4">
              <p class="text-sm font-semibold text-gray-900">{item}</p>
              <p class="mt-1 text-sm text-gray-500">Placeholder only. Replace with the final image asset when ready.</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script id="tarpaulin-design-data" type="application/json" set:html={JSON.stringify(designData)}></script>

  <script type="module">
    const designDataElement = document.getElementById('tarpaulin-design-data');
    const canvas = document.getElementById('tarpaulin-canvas');
    const widthInput = document.getElementById('tarpaulin-width');
    const heightInput = document.getElementById('tarpaulin-height');
    const unitSelect = document.getElementById('tarpaulin-unit');
    const ppiSelect = document.getElementById('tarpaulin-ppi');
    const exportButton = document.getElementById('tarpaulin-export');
    const sizeSummary = document.getElementById('tarpaulin-size-summary');
    const ratioSummary = document.getElementById('tarpaulin-ratio-summary');
    const pixelSummary = document.getElementById('tarpaulin-pixel-summary');

    if (
      !(designDataElement instanceof HTMLScriptElement) ||
      !(canvas instanceof HTMLCanvasElement) ||
      !(widthInput instanceof HTMLInputElement) ||
      !(heightInput instanceof HTMLInputElement) ||
      !(unitSelect instanceof HTMLSelectElement) ||
      !(ppiSelect instanceof HTMLSelectElement) ||
      !(exportButton instanceof HTMLButtonElement) ||
      !(sizeSummary instanceof HTMLElement) ||
      !(ratioSummary instanceof HTMLElement) ||
      !(pixelSummary instanceof HTMLElement)
    ) {
      throw new Error('Tarpaulin page controls are missing.');
    }

    const designData = JSON.parse(designDataElement.textContent || '{}');
    const context = canvas.getContext('2d');
    const imageCache = new Map();
    const baseDesignWidth = 1600;
    const baseDesignHeight = 1000;
    const maxPreviewEdge = 1800;
    const maxExportPixels = 40000000;
    const unitToInches = {
      in: 1,
      ft: 12,
      cm: 1 / 2.54,
      m: 39.37007874,
    };

    if (!context) {
      throw new Error('Unable to acquire canvas rendering context.');
    }

    const brandBlue = '#0e6fca';
    const brandBlueDark = '#0a2d54';
    const brandBlueDeep = '#061a33';
    const accentGold = '#d4a017';
    const surfaceBlue = '#f5f9ff';
    const borderColor = '#d0e3f5';
    const textStrong = '#0f172a';
    const textBody = '#475569';
    const textMuted = '#64748b';
    let assetsPromise;
    let renderSequence = 0;

    const iconDrawers = {
      camera: (ctx, x, y, size) => {
        ctx.strokeStyle = brandBlueDark;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        ctx.roundRect(x + 8, y + 16, size - 16, size - 28, 10);
        ctx.stroke();
        ctx.beginPath();
        ctx.arc(x + size / 2, y + size / 2 + 4, 10, 0, Math.PI * 2);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(x + 18, y + 18);
        ctx.lineTo(x + 28, y + 10);
        ctx.lineTo(x + 42, y + 10);
        ctx.stroke();
      },
      printer: (ctx, x, y, size) => {
        ctx.strokeStyle = brandBlueDark;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        ctx.roundRect(x + 10, y + 18, size - 20, size - 28, 10);
        ctx.stroke();
        ctx.beginPath();
        ctx.rect(x + 18, y + 8, size - 36, 18);
        ctx.stroke();
        ctx.beginPath();
        ctx.rect(x + 18, y + 34, size - 36, 18);
        ctx.stroke();
      },
      id: (ctx, x, y, size) => {
        ctx.strokeStyle = brandBlueDark;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        ctx.roundRect(x + 8, y + 12, size - 16, size - 24, 10);
        ctx.stroke();
        ctx.beginPath();
        ctx.arc(x + 24, y + 30, 7, 0, Math.PI * 2);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(x + 18, y + 48);
        ctx.quadraticCurveTo(x + 24, y + 40, x + 30, y + 48);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(x + 40, y + 28);
        ctx.lineTo(x + size - 16, y + 28);
        ctx.moveTo(x + 40, y + 40);
        ctx.lineTo(x + size - 24, y + 40);
        ctx.stroke();
      },
      copy: (ctx, x, y, size) => {
        ctx.strokeStyle = brandBlueDark;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        ctx.roundRect(x + 18, y + 12, size - 28, size - 28, 8);
        ctx.stroke();
        ctx.beginPath();
        ctx.roundRect(x + 8, y + 22, size - 28, size - 28, 8);
        ctx.stroke();
      },
      spark: (ctx, x, y, size) => {
        ctx.strokeStyle = brandBlueDark;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        ctx.moveTo(x + size / 2, y + 10);
        ctx.lineTo(x + size / 2, y + size - 10);
        ctx.moveTo(x + 10, y + size / 2);
        ctx.lineTo(x + size - 10, y + size / 2);
        ctx.moveTo(x + 18, y + 18);
        ctx.lineTo(x + size - 18, y + size - 18);
        ctx.moveTo(x + size - 18, y + 18);
        ctx.lineTo(x + 18, y + size - 18);
        ctx.stroke();
      },
      scan: (ctx, x, y, size) => {
        ctx.strokeStyle = brandBlueDark;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        ctx.roundRect(x + 10, y + 16, size - 20, size - 30, 10);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(x + 16, y + size / 2);
        ctx.lineTo(x + size - 16, y + size / 2);
        ctx.moveTo(x + 20, y + 20);
        ctx.lineTo(x + 20, y + 10);
        ctx.moveTo(x + size - 20, y + 20);
        ctx.lineTo(x + size - 20, y + 10);
        ctx.stroke();
      },
      cut: (ctx, x, y, size) => {
        ctx.strokeStyle = brandBlueDark;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        ctx.arc(x + 20, y + 22, 7, 0, Math.PI * 2);
        ctx.arc(x + 20, y + 42, 7, 0, Math.PI * 2);
        ctx.moveTo(x + 26, y + 24);
        ctx.lineTo(x + size - 14, y + 12);
        ctx.moveTo(x + 26, y + 40);
        ctx.lineTo(x + size - 14, y + size - 12);
        ctx.stroke();
      },
      shield: (ctx, x, y, size) => {
        ctx.strokeStyle = brandBlueDark;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        ctx.moveTo(x + size / 2, y + 10);
        ctx.lineTo(x + size - 14, y + 18);
        ctx.lineTo(x + size - 18, y + 38);
        ctx.quadraticCurveTo(x + size / 2, y + size - 8, x + 18, y + 38);
        ctx.lineTo(x + 14, y + 18);
        ctx.closePath();
        ctx.stroke();
      },
    };

    function roundRectPath(ctx, x, y, width, height, radius) {
      ctx.beginPath();
      ctx.roundRect(x, y, width, height, radius);
    }

    function fillRoundRect(ctx, x, y, width, height, radius, fillStyle) {
      roundRectPath(ctx, x, y, width, height, radius);
      ctx.fillStyle = fillStyle;
      ctx.fill();
    }

    function strokeRoundRect(ctx, x, y, width, height, radius, strokeStyle, lineWidth = 1) {
      roundRectPath(ctx, x, y, width, height, radius);
      ctx.strokeStyle = strokeStyle;
      ctx.lineWidth = lineWidth;
      ctx.stroke();
    }

    function createLayoutMetrics(targetWidth, targetHeight) {
      const scale = Math.min(targetWidth / baseDesignWidth, targetHeight / baseDesignHeight);

      return {
        width: targetWidth,
        height: targetHeight,
        scale,
        x: (value) => (value / baseDesignWidth) * targetWidth,
        y: (value) => (value / baseDesignHeight) * targetHeight,
        size: (value) => value * scale,
        radius: (value) => Math.max(6, value * scale),
        line: (value) => Math.max(1, value * scale),
        font: (value) => Math.max(10, value * scale),
      };
    }

    function fitText(ctx, text, maxWidth, initialSize, minSize, weight = '700', family = 'Inter, sans-serif') {
      let fontSize = initialSize;
      while (fontSize > minSize) {
        ctx.font = `${weight} ${fontSize}px ${family}`;
        if (ctx.measureText(text).width <= maxWidth) return fontSize;
        fontSize -= 2;
      }
      return minSize;
    }

    function wrapText(ctx, text, maxWidth, maxLines = 3) {
      const words = text.split(' ');
      const lines = [];
      let currentLine = '';

      for (const word of words) {
        const trial = currentLine ? `${currentLine} ${word}` : word;
        if (ctx.measureText(trial).width <= maxWidth) {
          currentLine = trial;
          continue;
        }

        if (currentLine) lines.push(currentLine);
        currentLine = word;

        if (lines.length === maxLines - 1) break;
      }

      if (currentLine && lines.length < maxLines) {
        lines.push(currentLine);
      }

      if (lines.length === maxLines && words.join(' ') !== lines.join(' ')) {
        let lastLine = lines[maxLines - 1];
        while (ctx.measureText(`${lastLine}...`).width > maxWidth && lastLine.length > 0) {
          lastLine = lastLine.slice(0, -1).trim();
        }
        lines[maxLines - 1] = `${lastLine}...`;
      }

      return lines;
    }

    function loadImage(source) {
      if (!source) return Promise.resolve(null);
      if (imageCache.has(source)) return imageCache.get(source);

      const promise = new Promise((resolve) => {
        const image = new Image();
        image.onload = () => resolve(image);
        image.onerror = () => resolve(null);
        image.src = source;
      });

      imageCache.set(source, promise);
      return promise;
    }

    function drawPlaceholderImage(ctx, x, y, width, height, label, metrics) {
      fillRoundRect(ctx, x, y, width, height, 16, '#d1d5db');
      strokeRoundRect(ctx, x, y, width, height, metrics.radius(16), '#94a3b8', metrics.line(1.5));
      ctx.fillStyle = '#475569';
      ctx.font = `600 ${metrics.font(16)}px Inter, sans-serif`;
      ctx.textAlign = 'center';
      ctx.fillText(label, x + width / 2, y + height / 2 + 6);
      ctx.textAlign = 'left';
    }

    function drawImageCover(ctx, image, x, y, width, height, radius) {
      roundRectPath(ctx, x, y, width, height, radius);
      ctx.save();
      ctx.clip();

      if (image) {
        const scale = Math.max(width / image.width, height / image.height);
        const drawWidth = image.width * scale;
        const drawHeight = image.height * scale;
        const offsetX = x + (width - drawWidth) / 2;
        const offsetY = y + (height - drawHeight) / 2;
        ctx.drawImage(image, offsetX, offsetY, drawWidth, drawHeight);
      } else {
        const fallback = ctx.createLinearGradient(x, y, x + width, y + height);
        fallback.addColorStop(0, '#dbeafe');
        fallback.addColorStop(1, '#bfdbfe');
        ctx.fillStyle = fallback;
        ctx.fillRect(x, y, width, height);
      }

      ctx.restore();
    }

    function drawImageContain(ctx, image, x, y, width, height, radius) {
      roundRectPath(ctx, x, y, width, height, radius);
      ctx.save();
      ctx.clip();

      const fallback = ctx.createLinearGradient(x, y, x + width, y + height);
      fallback.addColorStop(0, '#dbeafe');
      fallback.addColorStop(1, '#bfdbfe');
      ctx.fillStyle = fallback;
      ctx.fillRect(x, y, width, height);

      if (image) {
        const scale = Math.min(width / image.width, height / image.height);
        const drawWidth = image.width * scale;
        const drawHeight = image.height * scale;
        const offsetX = x + (width - drawWidth) / 2;
        const offsetY = y + (height - drawHeight) / 2;
        ctx.drawImage(image, offsetX, offsetY, drawWidth, drawHeight);
      }

      ctx.restore();
    }

    function drawTopSection(ctx, images, metrics) {
      const gradient = ctx.createLinearGradient(0, 0, metrics.width, metrics.y(240));
      gradient.addColorStop(0, '#0e6fca');
      gradient.addColorStop(0.55, '#1a8de8');
      gradient.addColorStop(1, '#0a2d54');

      fillRoundRect(ctx, metrics.x(32), metrics.y(32), metrics.x(1536), metrics.y(240), metrics.radius(28), gradient);

      ctx.fillStyle = 'rgba(255,255,255,0.12)';
      ctx.beginPath();
      ctx.arc(metrics.x(1380), metrics.y(70), metrics.size(110), 0, Math.PI * 2);
      ctx.fill();
      ctx.beginPath();
      ctx.arc(metrics.x(1490), metrics.y(220), metrics.size(140), 0, Math.PI * 2);
      ctx.fill();

      ctx.fillStyle = '#dbeafe';
      ctx.font = `700 ${metrics.font(20)}px Inter, sans-serif`;
      ctx.fillText('TARPAULIN DESIGN PREVIEW', metrics.x(72), metrics.y(84));

      const titleSize = fitText(
        ctx,
        designData.businessName,
        metrics.x(760),
        metrics.font(78),
        metrics.font(40),
        '800',
        'Libre Baskerville, Georgia, serif'
      );
      ctx.fillStyle = '#ffffff';
      ctx.font = `800 ${titleSize}px Libre Baskerville, Georgia, serif`;
      ctx.fillText(designData.businessName, metrics.x(72), metrics.y(156));

      ctx.font = `600 ${metrics.font(26)}px Inter, sans-serif`;
      ctx.fillStyle = '#f8fafc';
      const phraseLines = wrapText(ctx, designData.title, metrics.x(760), 2);
      phraseLines.forEach((line, index) => {
        ctx.fillText(line, metrics.x(72), metrics.y(196) + index * metrics.y(32));
      });

      const chips = ['Fast Turnaround', 'Sharp Prints', 'Custom Layouts'];
      let chipX = metrics.x(72);
      chips.forEach((chip) => {
        const width = ctx.measureText(chip).width + metrics.x(34);
        fillRoundRect(ctx, chipX, metrics.y(220), width, metrics.y(34), metrics.radius(17), 'rgba(255,255,255,0.16)');
        ctx.fillStyle = '#ffffff';
        ctx.font = `600 ${metrics.font(16)}px Inter, sans-serif`;
        ctx.fillText(chip, chipX + metrics.x(17), metrics.y(242));
        chipX += width + metrics.x(12);
      });

      const previewImages = images.slice(0, 5);
      const printWidth = metrics.x(108);
      const printHeight = metrics.y(90);
      const printGap = metrics.x(10);
      const printY = metrics.y(98);
      const totalWidth = previewImages.length * printWidth + Math.max(0, previewImages.length - 1) * printGap;
      const startX = metrics.x(1544) - totalWidth;

      previewImages.forEach((image, index) => {
        const x = startX + index * (printWidth + printGap);
        ctx.save();
        ctx.translate(x + printWidth / 2, printY + printHeight / 2);
        ctx.rotate((-8 + index * 8) * Math.PI / 180);
        fillRoundRect(ctx, -printWidth / 2, -printHeight / 2, printWidth, printHeight, metrics.radius(16), '#ffffff');
        drawImageContain(ctx, image, -printWidth / 2 + metrics.x(8), -printHeight / 2 + metrics.y(8), printWidth - metrics.x(16), printHeight - metrics.y(16), metrics.radius(10));
        ctx.restore();
      });
    }

    function drawServiceList(ctx, metrics) {
      const leftX = metrics.x(24);
      const leftY = metrics.y(312);
      const leftWidth = metrics.x(500);
      const leftHeight = metrics.y(460);

      fillRoundRect(ctx, leftX, leftY, leftWidth, leftHeight, metrics.radius(18), '#f5f6f7');
      strokeRoundRect(ctx, leftX, leftY, leftWidth, leftHeight, metrics.radius(18), '#c7ced9', metrics.line(2));

      fillRoundRect(ctx, leftX + metrics.x(16), leftY - metrics.y(8), leftWidth - metrics.x(32), metrics.y(62), metrics.radius(14), '#07327f');
      ctx.fillStyle = '#ffffff';
      ctx.font = `900 ${metrics.font(48)}px Inter, sans-serif`;
      ctx.textAlign = 'center';
      ctx.fillText('OUR SERVICES', leftX + leftWidth / 2, leftY + metrics.y(35));
      ctx.textAlign = 'left';

      const serviceDescriptions = {
        'Photo Printing': 'Print your memories in high quality',
        'Document Printing': 'Black & white and color',
        'ID Pictures': '1x1, 2x2, passport and more',
        Photocopy: 'Clear and crisp copies',
        'Photo Enhancement': 'Enhance colors and sharpness',
        Scanning: 'High resolution scanning',
        'Background Removal': 'Remove or replace background',
        Lamination: 'Protect important documents',
      };

      const iconColors = ['#0f78d8', '#0ea5a6', '#e91e63', '#4caf50', '#5b2ea8', '#0f52ba', '#ef4444', '#d97706'];
      const startX = leftX + metrics.x(16);
      const startY = leftY + metrics.y(70);
      const rowHeight = metrics.y(92);
      const colWidth = metrics.x(236);

      designData.services.forEach((service, index) => {
        const column = index % 2;
        const row = Math.floor(index / 2);
        const cardX = startX + column * colWidth;
        const cardY = startY + row * rowHeight;

        if (row > 0) {
          ctx.strokeStyle = '#d6dbe5';
          ctx.lineWidth = metrics.line(1.2);
          ctx.beginPath();
          ctx.moveTo(cardX, cardY);
          ctx.lineTo(cardX + colWidth - metrics.x(16), cardY);
          ctx.stroke();
        }

        ctx.fillStyle = iconColors[index % iconColors.length];
        ctx.beginPath();
        ctx.arc(cardX + metrics.x(36), cardY + metrics.y(36), metrics.size(30), 0, Math.PI * 2);
        ctx.fill();

        const drawIcon = iconDrawers[service.icon];
        if (drawIcon) drawIcon(ctx, cardX + metrics.x(4), cardY + metrics.y(2), metrics.size(64));

        ctx.fillStyle = '#111c3d';
        ctx.font = `900 ${metrics.font(24)}px Inter, sans-serif`;
        const titleLines = wrapText(ctx, service.label.toUpperCase(), metrics.x(140), 2);
        titleLines.forEach((line, lineIndex) => {
          ctx.fillText(line, cardX + metrics.x(84), cardY + metrics.y(30) + lineIndex * metrics.y(22));
        });

        ctx.fillStyle = '#1f2937';
        ctx.font = `500 ${metrics.font(16)}px Inter, sans-serif`;
        const description = serviceDescriptions[service.label] || 'High-quality print service';
        const descLines = wrapText(ctx, description, metrics.x(140), 2);
        descLines.forEach((line, lineIndex) => {
          ctx.fillText(line, cardX + metrics.x(84), cardY + metrics.y(64) + lineIndex * metrics.y(17));
        });
      });

      // Footer strip intentionally removed to keep services panel cleaner.
    }

    function drawPackageGrid(ctx, images, metrics) {
      const rightX = metrics.x(542);
      const rightY = metrics.y(312);
      const rightWidth = metrics.x(1014);
      const rightHeight = metrics.y(460);

      fillRoundRect(ctx, rightX, rightY, rightWidth, rightHeight, metrics.radius(18), '#f5f6f7');
      strokeRoundRect(ctx, rightX, rightY, rightWidth, rightHeight, metrics.radius(18), '#c7ced9', metrics.line(2));

      fillRoundRect(ctx, rightX + metrics.x(14), rightY - metrics.y(8), rightWidth - metrics.x(20), metrics.y(62), metrics.radius(14), '#ec1073');
      ctx.fillStyle = '#ffffff';
      ctx.font = `900 ${metrics.font(38)}px Inter, sans-serif`;
      ctx.fillText('PHOTO PRINTING PACKAGES', rightX + metrics.x(34), rightY + metrics.y(35));

      const cardColors = ['#0d4fa6', '#2e9f3f', '#0891b2', '#6b329e', '#ea7a00', '#e11d24'];
      const cardX = rightX + metrics.x(24);
      const cardY = rightY + metrics.y(70);
      const cardWidth = metrics.x(312);
      const cardHeight = metrics.y(180);
      const colGap = metrics.x(14);
      const rowGap = metrics.y(18);

      designData.packages.slice(0, 6).forEach((pkg, index) => {
        const col = index % 3;
        const row = Math.floor(index / 3);
        const x = cardX + col * (cardWidth + colGap);
        const y = cardY + row * (cardHeight + rowGap);
        const frameColor = '#0a2d54';
        const accentColor = cardColors[index % cardColors.length];
        const image = images[index] || null;

        fillRoundRect(ctx, x, y, cardWidth, cardHeight, metrics.radius(20), frameColor);
        fillRoundRect(ctx, x + metrics.x(8), y + metrics.y(8), cardWidth - metrics.x(16), cardHeight - metrics.y(16), metrics.radius(15), '#ffffff');

        fillRoundRect(ctx, x + metrics.x(10), y + metrics.y(10), cardWidth - metrics.x(20), metrics.y(34), metrics.radius(10), accentColor);
        ctx.fillStyle = '#ffffff';
        ctx.font = `900 ${metrics.font(20)}px Inter, sans-serif`;
        ctx.textAlign = 'center';
        const cardTitle = wrapText(ctx, pkg.name.toUpperCase(), cardWidth - metrics.x(36), 1)[0] || pkg.name.toUpperCase();
        ctx.fillText(cardTitle, x + cardWidth / 2, y + metrics.y(33));
        ctx.textAlign = 'left';

        drawImageContain(
          ctx,
          image,
          x + metrics.x(18),
          y + metrics.y(52),
          cardWidth - metrics.x(36),
          metrics.y(74),
          metrics.radius(8)
        );
        if (!image) {
          drawPlaceholderImage(
            ctx,
            x + metrics.x(18),
            y + metrics.y(52),
            cardWidth - metrics.x(36),
            metrics.y(74),
            'Image',
            metrics
          );
        }

        const stickerRadius = metrics.size(28);
        const stripX = x + metrics.x(10);
        const stripY = y + cardHeight - metrics.y(46);
        const stripW = cardWidth - metrics.x(20);
        const stripH = metrics.y(36);

        fillRoundRect(ctx, stripX, stripY, stripW, stripH, metrics.radius(18), accentColor);
        ctx.fillStyle = '#ffffff';
        ctx.font = `600 ${metrics.font(14)}px Inter, sans-serif`;
        const shortDesc = wrapText(ctx, pkg.description, stripW - stickerRadius * 2 - metrics.x(24), 1)[0] || pkg.description;
        ctx.fillText(shortDesc, stripX + metrics.x(12), stripY + metrics.y(23));

        const stickerX = stripX + stripW - stickerRadius - metrics.x(4);
        const stickerY = stripY + stripH / 2;
        ctx.fillStyle = '#ffffff';
        ctx.beginPath();
        ctx.arc(stickerX, stickerY, stickerRadius, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = accentColor;
        ctx.lineWidth = metrics.line(3);
        ctx.beginPath();
        ctx.arc(stickerX, stickerY, stickerRadius, 0, Math.PI * 2);
        ctx.stroke();

        ctx.fillStyle = accentColor;
        ctx.font = `900 ${metrics.font(24)}px Inter, sans-serif`;
        ctx.textAlign = 'center';
        ctx.fillText(pkg.price.replace('PHP ', '₱'), stickerX, stickerY + metrics.y(8));
        ctx.textAlign = 'left';
      });
    }

    function drawBottomSection(ctx, metrics) {
      const gradient = ctx.createLinearGradient(metrics.x(32), metrics.y(802), metrics.x(1568), metrics.y(968));
      gradient.addColorStop(0, brandBlueDark);
      gradient.addColorStop(1, brandBlueDeep);
      fillRoundRect(ctx, metrics.x(32), metrics.y(802), metrics.x(1536), metrics.y(166), metrics.radius(28), gradient);

      ctx.fillStyle = '#ffffff';
      ctx.font = `800 ${metrics.font(30)}px Libre Baskerville, Georgia, serif`;
      ctx.fillText('Print smarter. Promote better. Stay memorable.', metrics.x(72), metrics.y(854));

      ctx.font = `500 ${metrics.font(18)}px Inter, sans-serif`;
      ctx.fillStyle = '#dbeafe';
      const copyLines = wrapText(ctx, designData.phrase, metrics.x(760), 2);
      copyLines.forEach((line, index) => {
        ctx.fillText(line, metrics.x(72), metrics.y(888) + index * metrics.y(24));
      });

      ctx.fillStyle = '#ffffff';
      ctx.font = `600 ${metrics.font(16)}px Inter, sans-serif`;
      ctx.fillText(`Phone: ${designData.phone}`, metrics.x(72), metrics.y(936));
      ctx.fillText(`Email: ${designData.email}`, metrics.x(360), metrics.y(936));
      ctx.fillText(`Website: ${designData.websiteUrl.replace(/^https?:\/\//, '')}`, metrics.x(760), metrics.y(936));

      const qrLabels = ['FB Page QR', 'Messenger QR', 'Website QR'];
      qrLabels.forEach((label, index) => {
        const x = metrics.x(1080 + index * 150);
        const y = metrics.y(836);
        fillRoundRect(ctx, x, y, metrics.size(118), metrics.size(118), metrics.radius(18), '#d1d5db');
        strokeRoundRect(ctx, x, y, metrics.size(118), metrics.size(118), metrics.radius(18), '#94a3b8', metrics.line(1.5));
        ctx.fillStyle = '#475569';
        ctx.font = `700 ${metrics.font(14)}px Inter, sans-serif`;
        const lines = wrapText(ctx, label, metrics.size(80), 2);
        ctx.textAlign = 'center';
        lines.forEach((line, lineIndex) => {
          ctx.fillText(line, x + metrics.size(59), y + metrics.size(52) + lineIndex * metrics.size(16));
        });
        ctx.textAlign = 'left';
      });
    }

    function getDimensionState() {
      const widthValue = Number(widthInput.value);
      const heightValue = Number(heightInput.value);
      const unit = unitSelect.value in unitToInches ? unitSelect.value : 'ft';
      const ppi = Number(ppiSelect.value) || 100;
      const safeWidth = Number.isFinite(widthValue) && widthValue > 0 ? widthValue : 6;
      const safeHeight = Number.isFinite(heightValue) && heightValue > 0 ? heightValue : 4;

      return {
        width: safeWidth,
        height: safeHeight,
        unit,
        ppi,
      };
    }

    function formatUnitLabel(unit) {
      return {
        ft: 'ft',
        in: 'in',
        cm: 'cm',
        m: 'm',
      }[unit] || unit;
    }

    function computePixelDimensions(state) {
      const inchesPerUnit = unitToInches[state.unit] || unitToInches.ft;
      return {
        widthPixels: Math.max(1, Math.round(state.width * inchesPerUnit * state.ppi)),
        heightPixels: Math.max(1, Math.round(state.height * inchesPerUnit * state.ppi)),
      };
    }

    function updateSummaries() {
      const state = getDimensionState();
      const { widthPixels, heightPixels } = computePixelDimensions(state);
      const aspectRatio = state.width / state.height;
      const orientation = aspectRatio >= 1 ? 'landscape' : 'portrait';

      sizeSummary.textContent = `${state.width} ${formatUnitLabel(state.unit)} × ${state.height} ${formatUnitLabel(state.unit)}`;
      const gcd = (a, b) => (b === 0 ? a : gcd(b, a % b));
      const normalizedWidth = Math.round(state.width * 10);
      const normalizedHeight = Math.round(state.height * 10);
      const divisor = gcd(normalizedWidth, normalizedHeight) || 1;
      ratioSummary.textContent = `${normalizedWidth / divisor}:${normalizedHeight / divisor} ${orientation}`;
      pixelSummary.textContent = `${widthPixels.toLocaleString()} × ${heightPixels.toLocaleString()} px at ${state.ppi} PPI`;
    }

    async function getLoadedAssets() {
      if (!assetsPromise) {
        assetsPromise = Promise.all([
          Promise.all(designData.samplePrints.map((item) => loadImage(item.imageUrl))),
          Promise.all(designData.packages.map((item) => loadImage(item.imageUrl))),
        ]).then(([sampleImages, packageImages]) => ({ sampleImages, packageImages }));
      }

      return assetsPromise;
    }

    function renderDesign(targetContext, targetWidth, targetHeight, assets) {
      const metrics = createLayoutMetrics(targetWidth, targetHeight);

      targetContext.setTransform(1, 0, 0, 1, 0, 0);
      targetContext.clearRect(0, 0, targetWidth, targetHeight);

      fillRoundRect(targetContext, 0, 0, targetWidth, targetHeight, 0, '#ffffff');
      fillRoundRect(targetContext, metrics.x(16), metrics.y(16), targetWidth - metrics.x(32), targetHeight - metrics.y(32), metrics.radius(32), '#eef6ff');

      drawTopSection(targetContext, assets.sampleImages, metrics);
      drawServiceList(targetContext, metrics);
      drawPackageGrid(targetContext, assets.packageImages, metrics);
      drawBottomSection(targetContext, metrics);
    }

    async function renderCanvas() {
      const renderId = ++renderSequence;
      const state = getDimensionState();
      const previewAspect = state.width / state.height;
      const previewWidth = previewAspect >= 1 ? maxPreviewEdge : Math.round(maxPreviewEdge * previewAspect);
      const previewHeight = previewAspect >= 1 ? Math.round(maxPreviewEdge / previewAspect) : maxPreviewEdge;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const assets = await getLoadedAssets();

      if (renderId !== renderSequence) return;

      canvas.width = Math.max(1, Math.round(previewWidth * dpr));
      canvas.height = Math.max(1, Math.round(previewHeight * dpr));
      canvas.style.width = '100%';
      canvas.style.height = 'auto';

      context.setTransform(dpr, 0, 0, dpr, 0, 0);
      renderDesign(context, previewWidth, previewHeight, assets);
      updateSummaries();
    }

    async function exportCanvas() {
      const state = getDimensionState();
      const { widthPixels, heightPixels } = computePixelDimensions(state);
      const totalPixels = widthPixels * heightPixels;

      if (totalPixels > maxExportPixels) {
        window.alert('The selected export is too large for a reliable browser-generated PNG. Reduce the size or choose a lower PPI.');
        return;
      }

      exportButton.disabled = true;
      exportButton.textContent = 'Exporting...';

      try {
        const assets = await getLoadedAssets();
        const exportCanvas = document.createElement('canvas');
        exportCanvas.width = widthPixels;
        exportCanvas.height = heightPixels;
        const exportContext = exportCanvas.getContext('2d');

        if (!exportContext) {
          throw new Error('Unable to create export canvas context.');
        }

        renderDesign(exportContext, widthPixels, heightPixels, assets);

        const blob = await new Promise((resolve) => exportCanvas.toBlob(resolve, 'image/png'));
        if (!blob) {
          throw new Error('PNG export failed.');
        }

        const fileName = `lkprint-tarpaulin-${state.width}x${state.height}-${state.unit}-${state.ppi}ppi.png`;
        const downloadUrl = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = downloadUrl;
        link.download = fileName;
        link.click();
        URL.revokeObjectURL(downloadUrl);
      } catch (error) {
        console.error(error);
        window.alert('Unable to export the tarpaulin image. Try a smaller size or lower PPI.');
      } finally {
        exportButton.disabled = false;
        exportButton.textContent = 'Export PNG';
      }
    }

    [widthInput, heightInput].forEach((input) => {
      input.addEventListener('input', () => {
        updateSummaries();
        renderCanvas();
      });
    });

    [unitSelect, ppiSelect].forEach((input) => {
      input.addEventListener('change', () => {
        updateSummaries();
        renderCanvas();
      });
    });

    exportButton.addEventListener('click', exportCanvas);

    updateSummaries();
    renderCanvas();
    window.addEventListener('resize', renderCanvas);
  </script>
</BaseLayout>